---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import PostCard from '@components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog-zh');
const publishedPosts = posts
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="" description="jilei.blog — 使用 Claude 的心得与技术分享" lang="zh" isHome={true}>
  <Header slot="header" lang="zh" currentPath={Astro.url.pathname} />

  <div class="max-w-5xl mx-auto px-4 py-16">
    <!-- 简介 -->
    <section class="mb-16">
      <h1 class="text-4xl font-bold mb-4">jilei.blog</h1>
      <p class="text-lg text-gray-500 dark:text-slate-400 max-w-2xl">
        记录使用 Claude 过程中的心得、技巧与问题解决方案。分享技术博客搭建经验与 AI 工作流实践。
      </p>
    </section>

    <!-- 最新文章 -->
    <section>
      <h2 class="text-xl font-semibold mb-6">最新文章</h2>
      <div class="grid gap-4">
        {publishedPosts.map(post => <PostCard post={post} lang="zh" />)}
      </div>
    </section>
  </div>

  <Footer slot="footer" lang="zh" />
</BaseLayout>
