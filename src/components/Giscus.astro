<!--
  评论系统 - Giscus
  基于 GitHub Discussions，无后端、无广告、零成本
-->
<section class="max-w-[720px] mx-auto mt-16 pt-8 border-t border-gray-100 dark:border-slate-800">
  <div id="giscus-comments"></div>
  <script is:inline>
    const container = document.getElementById('giscus-comments');
    if (container) {
      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'Sandwich-git/jileiblog');
      script.setAttribute('data-repo-id', 'R_kgDOSRuOaw');
      script.setAttribute('data-category', 'Blog Comments');
      script.setAttribute('data-category-id', 'DIC_kwDOSRuOa84C8ICE');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'top');
      script.setAttribute('data-theme', 'preferred_color_scheme');
      script.setAttribute('data-lang', 'zh-CN');
      script.setAttribute('data-loading', 'lazy');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;
      container.appendChild(script);
    }
  </script>
  <noscript>
    <p class="text-sm text-gray-400 text-center">请启用 JavaScript 查看评论。</p>
  </noscript>
</section>
