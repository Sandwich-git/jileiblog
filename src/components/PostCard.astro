---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog-zh'> | CollectionEntry<'blog-en'>;
  lang: string;
}

const { post, lang } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = `/${lang}/blog/${post.slug}/`;
---

<a
  href={href}
  class="block p-6 rounded-xl border border-gray-100 dark:border-slate-800 hover:border-blue-200 dark:hover:border-blue-800 hover:shadow-sm transition-all"
>
  <h2 class="text-lg font-semibold mb-2 text-gray-900 dark:text-slate-100">{title}</h2>
  <p class="text-sm text-gray-500 dark:text-slate-400 mb-3 line-clamp-2">{description}</p>
  <div class="flex items-center gap-2 text-xs text-gray-400 dark:text-slate-500">
    <time datetime={pubDate.toISOString()}>
      {pubDate.toLocaleDateString(
        lang === 'en' ? 'en-US' : 'zh-CN',
        { year: 'numeric', month: 'short', day: 'numeric' }
      )}
    </time>
    {tags.length > 0 && (
      <span class="flex gap-1.5">
        {tags.map(tag => (
          <span class="bg-gray-50 dark:bg-slate-800 px-2 py-0.5 rounded-full">{tag}</span>
        ))}
      </span>
    )}
  </div>
</a>
