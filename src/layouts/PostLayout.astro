---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog-zh'> | CollectionEntry<'blog-en'>;
  lang: string;
}

const { post, lang } = Astro.props;
const { title, description, tags } = post.data;
---

<BaseLayout title={title} description={description} lang={lang}>
  <Header slot="header" lang={lang} currentPath={Astro.url.pathname} />

  <article class="py-12 px-4">
    <!-- 文章头部 -->
    <header class="max-w-[720px] mx-auto mb-10">
      <h1 class="text-3xl font-bold mb-3">{title}</h1>
      <p class="text-gray-500 dark:text-slate-400 text-sm mb-4">{description}</p>
      <div class="flex flex-wrap gap-2 items-center text-sm text-gray-400 dark:text-slate-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString(
            lang === 'en' ? 'en-US' : 'zh-CN',
            { year: 'numeric', month: 'long', day: 'numeric' }
          )}
        </time>
        {post.data.updatedDate && (
          <>
            <span class="mx-1">·</span>
            <span>
              {lang === 'en' ? 'Updated ' : '更新于 '}
              {post.data.updatedDate.toLocaleDateString(
                lang === 'en' ? 'en-US' : 'zh-CN',
                { year: 'numeric', month: 'long', day: 'numeric' }
              )}
            </span>
          </>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-2 w-full">
            {tags.map(tag => (
              <span class="bg-gray-100 dark:bg-slate-800 text-gray-600 dark:text-slate-400 px-2.5 py-0.5 rounded-full text-xs">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- 正文 -->
    <slot />
  </article>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
